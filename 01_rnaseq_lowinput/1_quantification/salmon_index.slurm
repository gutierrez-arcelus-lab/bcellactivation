#!/usr/bin/bash

# ==============================================================================
# Description:  Builds the quasi-mapping index required by Salmon to quantify 
#               RNA-seq reads. It utilizes the primary assembly transcriptome 
#               FASTA generated in the preceding RSEM extraction step.
# Input:        gencode.v38.primary_assembly.transcripts.fa
# Output:       Salmon index directory (./index)
# Dependencies: Biogrids (Salmon v1.10.1)
# ==============================================================================

# ------------------------------------------------------------------------------
# SLURM DIRECTIVES
# ------------------------------------------------------------------------------

#SBATCH -N 1
#SBATCH -c 4
#SBATCH --mem=24gb
#SBATCH -t 24:00:00
#SBATCH -p bch-compute
#SBATCH -J Salmon-index
#SBATCH --mail-user=vitor.aguiar@childrens.harvard.edu
#SBATCH --mail-type=END,FAIL
#SBATCH -o logs/Salmon-index.%j.out
#SBATCH -e logs/Salmon-index.%j.err

# ------------------------------------------------------------------------------
# ENVIRONMENT SETUP
# ------------------------------------------------------------------------------
# Note: Biogrids is our institutional software environment manager. 
# If running this script on a different HPC cluster, replace the following 
# two lines with your local equivalent (e.g., `conda activate salmon`).
source /programs/biogrids.shrc
export SALMON_X=1.10.1

# Move to the directory where the job was submitted from
cd "$SLURM_SUBMIT_DIR"

# ------------------------------------------------------------------------------
# INPUT / OUTPUT DEFINITIONS
# ------------------------------------------------------------------------------
# Input: The transcriptome FASTA generated by the RSEM preparation script
GENCODE="./data/gencode.v38.primary_assembly.transcripts.fa"

# Output: The directory where the compiled Salmon index will be stored
INDEX="./index"

mkdir -p "$INDEX"

# ------------------------------------------------------------------------------
# EXECUTION
# ------------------------------------------------------------------------------
# Build the Salmon index
# -t       : Path to the target transcriptome FASTA file
# -i       : Path to the output index directory
# --tmpdir : Redirects temporary file generation to a specified temp directory 
salmon index -t "$GENCODE" -i "$INDEX" --tmpdir "${TEMP_WORK}/temp/salmon"
